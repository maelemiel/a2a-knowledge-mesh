# A2A Knowledge Mesh — Environment
#
# These variables configure the mesh.

# ── Authentication ──────────────────────────────────────────────────────
# Bearer tokens for agent-to-agent communication.
# Generate with: openssl rand -hex 32
A2A_REGISTRY_TOKEN=
A2A_KEEPER_TOKEN=
A2A_RECONCILER_TOKEN=
A2A_MASTER_TOKEN=                     # CLI / external tools
A2A_HMAC_SECRET=                      # 32+ byte hex string for HMAC signing

# ── Band Agent credentials ──────────────────────────────────────────────
# Get these from https://app.band.ai/agents
BAND_AGENT_ID=
BAND_API_KEY=

# ── LLM Providers (optional) ────────────────────────────────────────────
# Featherless AI (recommended — flat-rate open-source inference)
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=Qwen/Qwen2.5-14B-Instruct

# OpenAI (fallback if Featherless is not configured)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
