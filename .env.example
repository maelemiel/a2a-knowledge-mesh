# Knowledge Mesh — Environment
#
# Créez 5 agents sur https://app.band.ai → Settings → Agents
# Ajoutez-les tous dans la même room.
# Copiez les IDs et API keys ci-dessous.

# ── Band room ──────────────────────────────────────────────────────────
BAND_ROOM_ID=                          # Room ID where all agents chat
BAND_USER_HANDLE=                      # Your Band handle, e.g. eliott.raguin

# Optional explicit mention handles. Defaults match agent display names.
BAND_KEEPER_HANDLE=Keeper
BAND_RECONCILER_HANDLE=Reconciler
BAND_REGISTRY_HANDLE=Registry

# ── Band Agent credentials ────────────────────────────────────────────
# Scraper — parses git repos, sends facts to Keeper
BAND_SCRAPER_ID=
BAND_SCRAPER_KEY=

# Keeper — SQLite fact store, auto-detect conflicts
BAND_KEEPER_ID=
BAND_KEEPER_KEY=

# Reconciler — LLM conflict resolution, scoring, auto-resolve
BAND_RECONCILER_ID=
BAND_RECONCILER_KEY=

# Registry — agent directory / demo reset orchestrator
BAND_REGISTRY_ID=
BAND_REGISTRY_KEY=

# Bridge — mirrors room to dashboard (must be in the room)
BAND_BRIDGE_ID=
BAND_BRIDGE_KEY=

# ── LLM Provider (Featherless AI recommended) ─────────────────────────
# Get key: https://featherless.ai
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=Qwen/Qwen2.5-14B-Instruct

# OpenAI (fallback if Featherless is not configured)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Ports (optional, defaults below) ──────────────────────────────────
BRIDGE_PORT=8775                       # Bridge HTTP API
DASHBOARD_PORT=8776                    # Dashboard web UI
BRIDGE_URL=http://127.0.0.1:8775       # Dashboard proxy target
